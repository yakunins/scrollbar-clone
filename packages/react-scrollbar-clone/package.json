{
    "name": "react-scrollbar-clone",
    "version": "0.0.9",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/yakunins/scrollbar-clone",
        "directory": "packages/react-scrollbar-clone"
    },
    "files": [
        "dist/**"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts --external react",
        "dev": "tsup src/index.ts --format esm,cjs --watch --dts --external react",
        "lint": "eslint src/",
        "clean": "rimraf .turbo && rimraf node_modules && rimraf dist"
    },
    "dependencies": {
        "@lit/react": "^1.0.8"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "scrollbar-clone": ">=0.0.4"
    },
    "devDependencies": {
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "eslint-config-custom": "*",
        "react": "^19.1.0",
        "scrollbar-clone": "*",
        "tsconfig": "*",
        "tsup": "^8.5.1",
        "typescript": "^5.8.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
